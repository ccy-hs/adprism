rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /campaigns/{id} {
      allow read:  if true;
      // Allow updating only saved and dismissed fields from the client
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['saved', 'dismissed']);
      allow create, delete: if false;
    }
    match /brands/{id} {
      allow read:  if true;
      allow write: if false;
    }
    match /fcm_tokens/{id} {
      allow read:  if false;
      allow write: if true;
    }
  }
}
